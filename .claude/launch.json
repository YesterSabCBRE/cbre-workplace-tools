{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Site (static server)",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-ExecutionPolicy", "Bypass", "-File", ".claude/serve.ps1"],
      "port": 3000
    },
    {
      "name": "Worker (wrangler dev)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "dev", "--config", "worker/wrangler.toml", "--port", "8787"],
      "port": 8787
    }
  ]
}
